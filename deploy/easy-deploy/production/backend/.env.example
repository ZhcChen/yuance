# 元策正式环境 API 运行配置。
# 复制为服务器上的 .env 后填写真实值；不要提交真实密码、token、OSS AccessKey 或生产配置。


# ===== 镜像与环境开始 =====
YUANCE_API_IMAGE=yuance-api:latest
YUANCE_ENV=production
YUANCE_LOG_LEVEL=info
# ===== 镜像与环境结束 =====


# ===== 服务端口开始 =====
# API 默认只绑定宿主机本机地址，由 Caddy 反向代理访问。
YUANCE_API_BIND_IP=127.0.0.1
YUANCE_API_PORT=33033
YUANCE_HTTP_ADDR=0.0.0.0:33033
# ===== 服务端口结束 =====


# ===== SQLite 与数据目录开始 =====
YUANCE_DATABASE_URL=sqlite:///data/yuance.sqlite3
YUANCE_DATA_DIR=/data
# ===== SQLite 与数据目录结束 =====


# ===== 安全配置开始 =====
# 必填。HTTP session 签名密钥，建议 32 字节以上随机字符串。
YUANCE_SESSION_SECRET=
YUANCE_SESSION_TTL=12h
YUANCE_CACHE_SESSION_TTL=5m

# 必填。稳定主密钥，用于加密对象存储等运行时敏感配置；部署后不要随意更换。
YUANCE_SECURITY_MASTER_KEY=
# ===== 安全配置结束 =====


# ===== Docker 日志轮转开始 =====
DOCKER_LOG_MAX_SIZE=20m
DOCKER_LOG_MAX_FILE=2
# ===== Docker 日志轮转结束 =====


# ===== Docker 网络开始 =====
YUANCE_DOCKER_NETWORK=yuance
# ===== Docker 网络结束 =====


# ===== 对象存储说明开始 =====
# 阿里云 OSS 不在本文件配置；部署后由超级管理员在 /web/system/storage 动态填写。
# 需要保持 YUANCE_SECURITY_MASTER_KEY 稳定，否则已保存的 OSS Secret 无法解密。
# ===== 对象存储说明结束 =====
